# Treasury App Configuration
# Copy this file to .env and fill in your database details

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Optional: Auth mode (none | simple | header)
AUTH_MODE=none

# Optional: Base currency for conversions
BASE_CURRENCY=EUR

# Optional: Anomaly threshold (% change to flag)
ANOMALY_THRESHOLD=50

# Optional: ECB FX auto-fetch (true/false)
FX_AUTO_FETCH=true
